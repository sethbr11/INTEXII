@{
}
@model List<Customer>


<!-- Start Hero Section -->
<div class="hero" style="padding: 0px; margin-bottom: 2rem;">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Manage Users</h1>
                </div>
            </div>
            <div class="col-lg-7">
            </div>
        </div>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <td>Customer ID</td>
            <td>First Name</td>
            <td>Last Name</td>
            <td>Gender</td>
            <td>Country of Residence</td>

        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Take(100))
        {
            <tr>
                <td>@c.CustomerId</td>
                <td>@c.FirstName</td>
                <td>@c.LastName</td>
                <td>@c.Gender</td>
                <td>@c.CountryOfResidence</td>


                <td><a class="btn btn-info" asp-controller="Home" asp-action="AdminEditUser" asp-route-id="@c.CustomerId">Edit</a></td>
                <td><a class="btn btn-danger" asp-controller="Home" asp-action="DeleteUser" asp-route-id="@c.CustomerId">Delete</a></td>
            </tr>
        }
    </tbody>
</table>
