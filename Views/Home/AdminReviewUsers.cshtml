@{
}
@model List<Customer>
<!-- Start Hero Section -->
<div class="hero" style="padding: 0px; margin-bottom: 2rem;">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Manage Users</h1>
                </div>
            </div>
            <div class="col-lg-7">
            </div>
        </div>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <td>CustomerID</td>
            <td>First Name</td>
            <td>Last Name</td>
            <td>Birth Date</td>
            <td>Country of Residence</td>
            <td>Gender</td>
            <td>Age</td>
            <td>Username</td>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CustomerId</td>
                <td>@c.FirstName</td>
                <td>@c.LastName</td>
                <td>@c.BirthDate</td>
                <td>@c.CountryOfResidence</td>
                <td>@c.Gender</td>
                <td>@c.Age</td>
                <td>@c.Username</td>
            </tr>
        }
    </tbody>
</table>
