@{
}

@model ProductsListViewModel

<h1>Shop</h1>


@foreach (Product p in Model.Products) {
    <partial name="ProductSummary" model="p" />
}

<div page-model="@Model.PaginationInfo" page-action="Shop" page-classes-enabled="true"
     page-class="btn" page-class-normal="btn-outline-dark" page-class-selected="btn-primary"
     page-url-projectType="@Model.CurrentProdCategory" class="btn-group pull-right m-1"></div>