@{}

@model List<Product>

<br /><br />
@if (Model != null) {
	<div class="container">
		<div class="row">
			@foreach (Product p in Model) {
				<div class="col-12 col-md-4 col-lg-3 mb-5" style="width: 33.33%">
					<a class="product-item" style="height: 100%;" asp-area="" asp-controller="Home" asp-action="ProductDetail"
					   asp-route-productId="@p.ProductId"
					   asp-route-returnUrl="@Model">
						<img src="@p.ImgLink" class="img-fluid product-thumbnail" onclick="redirectToProduct()">
						<h3 class="product-title">@p.Name</h3>
						<strong class="product-price">$@p.Price</strong>
					</a>
				</div>
			}
		</div>
	</div>
} else {
    <div class="center">
        <h3>Enter your username below</h3>
        <form method="post">
            <input type="text" name="username">
            <button type="submit">Submit</button>
        </form>
    </div>
}

