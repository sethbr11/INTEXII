}
@using INTEXII.Models
@model Customer

<div class="hero" style="padding: 0px; margin-bottom: 5rem;">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Are you sure you want to Delete?</h1>
                </div>
            </div>
            <div class="col-lg-7">
            </div>
        </div>
    </div>
</div>
<form method="post">
    <input type="hidden" asp-for="CustomerId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-info" asp-controller="Home" asp-action="AdminReviewUsers">Cancel</a>
</form>

