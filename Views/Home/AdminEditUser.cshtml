@{
}

@model Customer
<!--Form for the admin to add/edit a product to the database-->


<div>
    <div class="container">
        <div class="intro-excerpt" style="text-align: center;">
            <h1>
                Edit the Following
            </h1>
        </div>
    </div>
</div>


<form method="post" style="max-width: 600px; margin: 0 auto; padding: 2rem; background-color: #f9f9f9; border-radius: 8px; box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);">
    <input asp-for="CustomerId" hidden />

    <label asp-for="FirstName">FirstName: </label>
    <input asp-for="FirstName" style="display: block; width: 100%; padding: 0.5rem; margin-bottom: 1rem; border: 1px solid #ccc; border-radius: 15px; box-sizing: border-box;" /><br />

    <label asp-for="LastName">FirstName: </label>
    <input asp-for="LastName" style="display: block; width: 100%; padding: 0.5rem; margin-bottom: 1rem; border: 1px solid #ccc; border-radius: 15px; box-sizing: border-box;" /><br />

    <label asp-for="Gender">Gender: </label>
    <select asp-for="Gender" style="display: block; width: 100%; padding: 0.5rem; margin-bottom: 1rem; border: 1px solid #ccc; border-radius: 15px;">
        <option value="" disabled >- select -</option>
        <option value="M">Male</option>
        <option value="F">Female</option>
    </select><br />

  
    <button type="submit" style="display: block; width: 100%; padding: 0.75rem; border: none; border-radius: 15px; background-color: #007bff; color: white; cursor: pointer;">Submit</button>
</form>
