@model List<Product>
@{
    ViewData["Title"] = "Manage Products | AuroraBricks";
}

<!-- Start Hero Section -->
<div class="hero" style="padding: 0px; margin-bottom: 5rem;">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Admin Dashboard</h1>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End Hero Section -->

<div class="bodything">
    <!-- Start Admin Toolbox -->
    <div class="thing1">
        <div class="thing3">
            <h1>Admin Toolbox</h1>
        </div>
        <div class="thing2">
            <a asp-controller="Home" asp-action="AdminReviewProducts" class="btn btn-primary mybtns w-100">
                <p style="margin-bottom: 0rem;">Manage Products</p>
            </a>
            <a asp-controller="Home" asp-action="AdminReviewUsers" class="btn btn-primary mybtns w-100">
                <p style="margin-bottom: 0rem;">Manage Users</p>
            </a>
            <a asp-controller="Home" asp-action="ReviewOrders" class="btn btn-primary mybtns w-100">
                <p style="margin-bottom: 0rem;">Review Orders</p>
            </a>
            <a asp-controller="Home" asp-action="AdminAddProduct" class="btn btn-primary mybtns2 w-100 d-flex align-items-center justify-content-center text-center">
                <p style="margin-bottom: 0rem; font-size: 1.25rem;">Add Product <i class="fa-solid fa-plus ms-2"></i></p>
            </a>
        </div>
    </div>
    <!-- End Admin Toolbox -->

    <!-- Dynamic Product List -->
    <div style="width: 100%;">
        <div class="ps-md-4">
            <h2 class="mb-4 font-weight-bold" style="color: black;">Product Catalog (@Model.Count items)</h2>
            
            @if (Model.Count == 0)
            {
                <div class="alert alert-info">No products found in the database.</div>
            }
            else
            {
                @foreach (var p in Model)
                {
                    <div class="thing1-2 mb-4 p-3 d-flex align-items-center" style="background-color: #f9f9f9; border-radius: 12px; border: 1px solid #eee;">
                        <img src="@p.ImgLink" alt="@p.Name" class="myimages" style="max-height: 120px; max-width: 120px; object-fit: contain; border-radius: 8px; margin-right: 2rem;">
                        <div class="thing3-2 flex-grow-1">
                            <h3 style="color: black; margin-bottom: 0.5rem;" class="font-weight-bold">@p.Name</h3>
                            <p style="font-size: 0.95rem; color: #555; margin-bottom: 0.5rem;">@p.Description</p>
                            <p style="font-size: 0.9rem; margin-bottom: 0rem; font-weight: 600; color: #222;">
                                Price: <span style="color: #2b7a78;">$@p.Price</span> | 
                                Year: @p.Year | 
                                Parts: @p.NumParts | 
                                Color: @p.PrimaryColor | 
                                Category: @p.Category
                            </p>
                        </div>
                        <div class="d-flex align-items-center ms-3">
                            <a asp-controller="Home" asp-action="AdminAddProduct" asp-route-id="@p.ProductId" class="btn btn-link p-2" title="Edit Product">
                                <i class="fa-solid fa-pen-to-square fa-2x" style="color: #0d6efd;"></i>
                            </a>
                            <a asp-controller="Home" asp-action="Delete" asp-route-id="@p.ProductId" class="btn btn-link p-2 ms-2" title="Delete Product">
                                <i class="fa-solid fa-trash fa-2x" style="color: #dc3545;"></i>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
