@{
}
@model List<Product>
<h1>Welcome! Review products </h1>
<div>
    <a asp-controller="Home" asp-action="AdminAddProduct">Add a product</a>
</div>
<br />
<h3>Product Table</h3>
<table class="table">
    <thead>
        <tr>
            <td>Product ID</td>
            <td>Name</td>
            <td>Year</td>
            <td>Num Parts</td>
            <td>Price</td>
            <td>Img Link</td>
            <td>Primary Color</td>
            <td>Secondary Color</td>
            <!---<td>Description</td>-->
            <td>Category</td>
            <td>Rec1</td>
            <td>Sim1</td>
            <td>Rec2</td>
            <td>Sim2</td>
            <td>Rec3</td>
            <td>Sim3</td>
            <td>Rec4</td>
            <td>Sim4</td>
            <td>Rec5</td>
            <td>Sim5</td>
            <td>PopularityRank</td>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.ProductId</td>
                <td>@p.Name</td>
                <td>@p.Year</td>
                <td>@p.NumParts</td>
                <td>@p.Price</td>
                <td>@p.ImgLink</td>
                <td>@p.PrimaryColor</td>
                <td>@p.SecondaryColor</td>
                <!--<td>p.Description</td>-->
                <td>@p.Category</td>
                <td>@p.Recommendation1</td>
                <td>@p.Similarity1</td>
                <td>@p.Recommendation2</td>
                <td>@p.Similarity2</td>
                <td>@p.Recommendation3</td>
                <td>@p.Similarity3</td>
                <td>@p.Recommendation4</td>
                <td>@p.Similarity4</td>
                <td>@p.Recommendation5</td>
                <td>@p.Similarity5</td>
                <td>@p.PopularityRank</td>

                <td><a class="btn btn-info" asp-controller="Home" asp-action="AdminAddProduct" asp-route-id="@p.ProductId">Edit</a></td>
                <td><a class="btn btn-danger" asp-controller="Home" asp-action="Delete" asp-route-id="@p.ProductId">Delete</a></td>
            </tr>
        }
    </tbody>
    </table>
