@{
}
@using INTEXII.Infrastructure
@model Product

<div class="card m-1 p-1">
    <h4>
        @Model.Name
        <span class="badge rounded-pill bg-primary text-white float-end">
            <small>@*Model.ProjectImpact served*@</small>
        </span>
    </h4>
    <ul>
        <li>Project Type: @*Model.ProjectType*@</li>
        <li>Regional Program: @*Model.ProgramName*@</li>
        <li>Installation Date: @*Model.ProjectInstallation*@</li>
        <li>Phase: @*Model.ProjectPhase*@</li>
    </ul>

    <form id="@Model.ProductId" method="post" asp-page="/Cart">
        <input type="hidden" asp-for="@Model.ProductId" />
        <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
        <button type="submit" class="btn-outline-success btn-sm float-end">Donate</button>
    </form>
</div>