@{
}
@using INTEXII.Infrastructure
@model Product

<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="ProductDetail" 
                        asp-route-productId="@Model.ProductId" 
                        asp-route-returnUrl="@ViewContext.HttpContext.Request.PathAndQuery()">
    <div class="card m-1 p-1">
        <img src="@Model.ImgLink" alt="@Model.Name Image" style="width:300px;" />
        <h4>@Model.Name</h4>
        <h3>$@Model.Price</h3>

        <form id="@Model.ProductId" method="post" asp-page="/Cart">
            <input type="hidden" asp-for="@Model.ProductId" />
            <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
            <button type="submit" class="btn-outline-success btn-sm float-end">Add to Cart</button>
        </form>
    </div>
</a>