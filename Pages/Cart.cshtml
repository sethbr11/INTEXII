@page
@model INTEXII.Pages.CartModel
@{
}

<!-- Start Hero Section -->
<div class="hero" style="padding: 0px; margin-bottom: 5rem;">
    <div class="container">
        <div class="intro-excerpt">
            <h1>Cart</h1>
        </div>  
    </div>
</div>
<!-- End Hero Section -->
<div>
    <table class="table" style="width: 80%;">
            <tr>
                <th class="product-thumbnail">Image</th>
                <th class="product-name">Product</th>
                <th class="product-name">Quantity</th>
                <th class="product-price">Price</th>
                <th class="text-right">Subtotal</th>
                <th class="product-remove">Remove</th>
                <th></th>
            </tr>
    <tbody>
    @foreach (var l in Model.Cart?.Lines ?? Enumerable.Empty<Cart.CartLine>())
    {
        <tr>
                <td class="product-thumbnail"><img src="@l.Product.ImgLink" height="200" width="200" class="img-fluid" /></td>
                <td class="text-left">@l.Product.Name</td>
                <td class="text-center">@l.Quantity</td>
                <td class="text-right">$@l.Product.Price</td>
                <td class="text-right">@((l.Quantity * l.Product.Price).ToString("c"))</td>

            <td class="text-center">
                <form asp-page-handler="Remove" method="post">
                    <input type="hidden" name="productId" value="@l.Product.ProductId" />
                    <input type="hidden" name="returnUrl" value="@Model?.ReturnUrl" />
                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>

<div class="untree_co-section before-footer-section">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <div class="row">
                    <div class="col-md-12">
                        <label class="text-black h4" for="coupon">Coupon</label>
                        <p>Enter your coupon code if you have one.</p>
                    </div>
                    <div class="col-md-8 mb-3 mb-md-0">
                        <input type="text" class="form-control py-3" id="coupon" placeholder="Coupon Code">
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-black">Apply Coupon</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6 pl-5">
                <div class="row justify-content-end">
                    <div class="col-md-7">
                        <div class="row">
                            <div class="col-md-12 text-right border-bottom mb-5">
                                <h3 class="text-black h4 text-uppercase">Cart Total</h3>
                            </div>
                        </div>
                            <div class="row">
                                <div class="col-md-12 text-right" style="font-size: 24px;">
                                    <span>Total:</span>
                                    <span>@Model.Cart?.CalculateTotal().ToString("c")</span>
                                </div>
                            </div>
                        <div class="row">
                            <div class="col-md-12">
                                    <a class="btn btn-black btn-lg py-3 btn-block" asp-controller="Home" asp-action="Checkout">Proceed To Checkout</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center">
    <a class="btn btn-primary" href="@Model.ReturnUrl">Coninue Shopping</a>
</div>



